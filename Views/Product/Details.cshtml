@model Product

@{
    ViewData["Title"] = Model.Name;
}

<nav class="flex mb-6" aria-label="Breadcrumb">
    <ol role="list" class="flex items-center space-x-2">
        <li>
            <a asp-action="Index" class="text-gray-400 hover:text-gray-500">Products</a>
        </li>
        <li>
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
            </svg>
        </li>
        <li>
            <a asp-action="Index" asp-route-categoryId="@Model.CategoryId" class="text-gray-400 hover:text-gray-500">@Model.Category.Name</a>
        </li>
        <li>
            <svg class="h-5 w-5 flex-shrink-0 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                <path d="M5.555 17.776l8-16 .894.448-8 16-.894-.448z" />
            </svg>
        </li>
        <li class="text-sm font-medium text-gray-500">@Model.Name</li>
    </ol>
</nav>


<div class="mt-8 lg:mt-0">
    <span class="text-sm font-medium text-indigo-600">@Model.Category.Name</span>
    <h1 class="mt-2 text-3xl font-bold tracking-tight text-gray-900">@Model.Name</h1>

    <p class="mt-6 text-4xl font-bold tracking-tight text-gray-900">@Model.Price?.ToString("C")</p>

    <div class="mt-6">
        <h3 class="sr-only">Description</h3>
        <p class="text-base text-gray-700">@Model.Description</p>
    </div>

    <div class="mt-6">
        @if (Model.StockQuantity > 0)
        {
            <span class="inline-flex items-center rounded-full bg-green-100 px-3 py-1 text-sm font-medium text-green-800">
                <svg class="mr-1.5 h-4 w-4 text-green-600" fill="currentColor" viewBox="0 0 8 8">
                    <circle cx="4" cy="4" r="3" />
                </svg>
                In Stock
            </span>
            <span class="ml-2 text-sm text-gray-500">@Model.StockQuantity available</span>
        }
        else
        {
            <span class="inline-flex items-center rounded-full bg-red-100 px-3 py-1 text-sm font-medium text-red-800">
                <svg class="mr-1.5 h-4 w-4 text-red-600" fill="currentColor" viewBox="0 0 8 8">
                    <circle cx="4" cy="4" r="3" />
                </svg>
                Out of Stock
            </span>
        }
    </div>

    @if (Model.StockQuantity > 0)
    {
        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="mt-8">
            <input type="hidden" name="productId" value="@Model.ProductId" />
            <div class="flex items-center gap-4">
                <label for="quantity" class="text-sm font-medium text-gray-700">Quantity:</label>
                <input type="number" name="quantity" id="quantity" value="1" min="1" max="@Model.StockQuantity"
                       class="w-20 rounded-md border-0 py-2 text-gray-900 ring-1 ring-inset ring-gray-300 focus:ring-2 focus:ring-inset focus:ring-indigo-600 sm:text-sm" />
            </div>
            <button type="submit" class="mt-6 flex w-full items-center justify-center rounded-md bg-indigo-600 px-8 py-3 text-base font-medium text-white hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
                <svg class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
                </svg>
                Add to Cart
            </button>
        </form>
    }

    <div class="mt-8 border-t border-gray-200 pt-8 flex gap-4">
        <a asp-action="Index" class="inline-flex items-center text-sm font-medium text-gray-600 hover:text-gray-500">
            <svg class="mr-2 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
            </svg>
            Back to Products
        </a>
    </div>
</div>

