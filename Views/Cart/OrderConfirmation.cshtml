@model Order


@{
    ViewData["Title"] = "Order Confirmation";
}


<div class="text-center mb-8">
    <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-green-100">
        <svg class="h-10 w-10 text-green-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
    </div>
    <h1 class="mt-4 text-3xl font-bold text-gray-900">Thank You for Your Order!</h1>
    <p class="mt-2 text-lg text-gray-600">Your order has been placed successfully.</p>
</div>


<div class="mx-auto max-w-2xl">
    <div class="bg-white shadow rounded-lg overflow-hidden">
        <div class="border-b border-gray-200 bg-gray-50 px-6 py-4">
            <h2 class="text-lg font-medium text-gray-900">Order #@Model.OrderId</h2>
        </div>

        <div class="px-6 py-6">
            <div class="grid grid-cols-2 gap-6 mb-6">
                <div>
                    <dt class="text-sm font-medium text-gray-500">Order Date</dt>
                    <dd class="mt-1 text-sm text-gray-900">@Model.OrderDate.ToString("MMMM dd, yyyy h:mm tt")</dd>
                </div>
                <div>
                    <dt class="text-sm font-medium text-gray-500">Status</dt>
                    <dd class="mt-1">
                        <span class="inline-flex items-center rounded-full bg-yellow-100 px-2.5 py-0.5 text-xs font-medium text-yellow-800">
                            @Model.Status
                        </span>
                    </dd>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ShippingAddress))
            {
                <div class="mb-6">
                    <dt class="text-sm font-medium text-gray-500">Shipping Address</dt>
                    <dd class="mt-1 text-sm text-gray-900">@Model.ShippingAddress</dd>
                </div>
            }

            <div>
                <h3 class="text-sm font-medium text-gray-900 mb-4">Order Items</h3>
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead>
                            <tr>
                                <th class="py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Product</th>
                                <th class="py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Qty</th>
                                <th class="py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Unit Price</th>
                                <th class="py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-200">
                            @foreach (var item in Model.OrderItems)
                            {
                                <tr>
                                    <td class="py-4 text-sm text-gray-900">@item.Product.Name</td>
                                    <td class="py-4 text-sm text-gray-500">@item.Quantity</td>
                                    <td class="py-4 text-sm text-gray-500">@item.UnitPrice.ToString("C")</td>
                                    <td class="py-4 text-sm text-gray-900 text-right">@item.TotalPrice.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="border-t-2 border-gray-300">
                                <td colspan="3" class="py-4 text-right text-sm font-medium text-gray-900">Order Total</td>
                                <td class="py-4 text-right text-base font-bold text-gray-900">@Model.TotalAmount.ToString("C")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-8 flex justify-center gap-4">
        <a asp-controller="Product" asp-action="Index" class="rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500">
            Continue Shopping
        </a>
        <a asp-controller="Order" asp-action="Index" class="rounded-md bg-white px-4 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50">
            View All Orders
        </a>
    </div>
</div>
