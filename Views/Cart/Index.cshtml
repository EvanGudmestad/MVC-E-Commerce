@model CartViewModel


@{
    ViewData["Title"] = "Shopping Cart";
}

<h1 class="text-3xl font-bold text-gray-900 mb-6">Shopping Cart</h1>


@if (TempData["Message"] != null)
{
    <div class="rounded-md bg-green-50 p-4 mb-6">
        <div class="flex">
            <svg class="h-5 w-5 text-green-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.857-9.809a.75.75 0 00-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 10-1.06 1.061l2.5 2.5a.75.75 0 001.137-.089l4-5.5z" clip-rule="evenodd" />
            </svg>
            <p class="ml-3 text-sm font-medium text-green-800">@TempData["Message"]</p>
        </div>
    </div>
}


@if (TempData["Error"] != null)
{
    <div class="rounded-md bg-red-50 p-4 mb-6">
        <div class="flex">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.28 7.22a.75.75 0 00-1.06 1.06L8.94 10l-1.72 1.72a.75.75 0 101.06 1.06L10 11.06l1.72 1.72a.75.75 0 101.06-1.06L11.06 10l1.72-1.72a.75.75 0 00-1.06-1.06L10 8.94 8.28 7.22z" clip-rule="evenodd" />
            </svg>
            <p class="ml-3 text-sm font-medium text-red-800">@TempData["Error"]</p>
        </div>
    </div>
}


@if (Model.IsEmpty)
{
    <div class="rounded-md bg-blue-50 p-6 text-center">
        <svg class="mx-auto h-12 w-12 text-blue-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z" />
        </svg>
        <h3 class="mt-2 text-lg font-semibold text-gray-900">Your cart is empty</h3>
        <p class="mt-1 text-sm text-gray-500">Browse our <a asp-controller="Product" asp-action="Index" class="text-indigo-600 hover:text-indigo-500 font-medium">products</a> to start shopping!</p>
    </div>
}
else
{
    <div class="lg:grid lg:grid-cols-12 lg:gap-x-12">
        <div class="lg:col-span-8">
            <div class="bg-white shadow rounded-lg overflow-hidden">
                <ul role="list" class="divide-y divide-gray-200">
                    @foreach (var item in Model.Items)
                    {
                        <li class="flex px-4 py-6 sm:px-6">
                            <div class="h-24 w-24 flex-shrink-0 overflow-hidden rounded-md border border-gray-200">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.ProductName" class="h-full w-full object-cover object-center" />
                                }
                                else
                                {
                                    <div class="h-full w-full bg-gray-200 flex items-center justify-center">
                                        <svg class="h-8 w-8 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 15.75 5.159-5.159a2.25 2.25 0 0 1 3.182 0l5.159 5.159m-1.5-1.5 1.409-1.409a2.25 2.25 0 0 1 3.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 0 0 1.5-1.5V6a1.5 1.5 0 0 0-1.5-1.5H3.75A1.5 1.5 0 0 0 2.25 6v12a1.5 1.5 0 0 0 1.5 1.5Zm10.5-11.25h.008v.008h-.008V8.25Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z" />
                                        </svg>
                                    </div>
                                }
                            </div>

                            <div class="ml-4 flex flex-1 flex-col">
                                <div class="flex justify-between text-base font-medium text-gray-900">
                                    <h3>@item.ProductName</h3>
                                    <p class="ml-4">@item.TotalPrice.ToString("C")</p>
                                </div>
                                <p class="mt-1 text-sm text-gray-500">@item.Price.ToString("C") each</p>

                                <div class="flex flex-1 items-end justify-between text-sm mt-4">
                                    <form asp-action="UpdateQuantity" method="post" class="flex items-center gap-2">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <label class="text-gray-500">Qty:</label>
                                        <input type="number" name="quantity" value="@item.Quantity" min="1" max="99" class="w-16 rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm px-2 py-1" />
                                        <button type="submit" class="text-indigo-600 hover:text-indigo-500 font-medium">Update</button>
                                    </form>

                                    <form asp-action="RemoveFromCart" method="post">
                                        <input type="hidden" name="productId" value="@item.ProductId" />
                                        <button type="submit" class="font-medium text-red-600 hover:text-red-500 flex items-center">
                                            <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="m14.74 9-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 0 1-2.244 2.077H8.084a2.25 2.25 0 0 1-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 0 0-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 0 1 3.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 0 0-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 0 0-7.5 0" />
                                            </svg>
                                            Remove
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </li>
                    }
                </ul>
            </div>

            <form asp-action="ClearCart" method="post" class="mt-4">
                <button type="submit" class="text-sm font-medium text-red-600 hover:text-red-500">Clear Cart</button>
            </form>
        </div>

        <div class="lg:col-span-4 mt-8 lg:mt-0">
            <div class="bg-white shadow rounded-lg p-6">
                <h2 class="text-lg font-medium text-gray-900">Order Summary</h2>

                <dl class="mt-6 space-y-4">
                    <div class="flex items-center justify-between">
                        <dt class="text-sm text-gray-600">Subtotal (@Model.ItemCount items)</dt>
                        <dd class="text-sm font-medium text-gray-900">@Model.SubTotal.ToString("C")</dd>
                    </div>
                    <div class="flex items-center justify-between border-t border-gray-200 pt-4">
                        <dt class="text-sm text-gray-600">Tax (7%)</dt>
                        <dd class="text-sm font-medium text-gray-900">@Model.Tax.ToString("C")</dd>
                    </div>
                    <div class="flex items-center justify-between border-t border-gray-200 pt-4">
                        <dt class="text-base font-medium text-gray-900">Order total</dt>
                        <dd class="text-base font-medium text-gray-900">@Model.Total.ToString("C")</dd>
                    </div>
                </dl>

                <a asp-action="Checkout" class="mt-6 block w-full rounded-md bg-indigo-600 px-3 py-3 text-center text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
                    Proceed to Checkout
                </a>
            </div>
        </div>
    </div>
}

<div class="mt-6">
    <a asp-controller="Product" asp-action="Index" class="inline-flex items-center text-sm font-medium text-indigo-600 hover:text-indigo-500">
        <svg class="mr-2 h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M17 10a.75.75 0 01-.75.75H5.612l4.158 3.96a.75.75 0 11-1.04 1.08l-5.5-5.25a.75.75 0 010-1.08l5.5-5.25a.75.75 0 111.04 1.08L5.612 9.25H16.25A.75.75 0 0117 10z" clip-rule="evenodd" />
        </svg>
        Continue Shopping
    </a>
</div>
