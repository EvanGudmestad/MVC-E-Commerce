@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-sm">
        <h1 class="mt-10 text-center text-2xl/9 font-bold tracking-tight text-gray-900">@ViewData["Title"]</h1>
    </div>

    <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-sm">
        <form id="account" method="post" class="space-y-6">
            <h2 class="text-lg font-semibold text-gray-700">Use a local account to log in</h2>
            <div asp-validation-summary="ModelOnly" class="rounded-md bg-red-50 p-4 text-sm text-red-700" role="alert"></div>

            <div>
                <label asp-for="Input.Email" class="block text-sm/6 font-medium text-gray-900">Email</label>
                <div class="mt-2">
                    <input asp-for="Input.Email" autocomplete="username" aria-required="true" placeholder="name@example.com"
                           class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
                </div>
                <span asp-validation-for="Input.Email" class="mt-1 text-sm text-red-600"></span>
            </div>

            <div>
                <div class="flex items-center justify-between">
                    <label asp-for="Input.Password" class="block text-sm/6 font-medium text-gray-900">Password</label>
                    <div class="text-sm">
                        <a id="forgot-password" asp-page="./ForgotPassword" class="font-semibold text-indigo-600 hover:text-indigo-500">Forgot password?</a>
                    </div>
                </div>
                <div class="mt-2">
                    <input asp-for="Input.Password" autocomplete="current-password" aria-required="true" placeholder="password"
                           class="block w-full rounded-md bg-white px-3 py-1.5 text-base text-gray-900 outline-1 -outline-offset-1 outline-gray-300 placeholder:text-gray-400 focus:outline-2 focus:-outline-offset-2 focus:outline-indigo-600 sm:text-sm/6" />
                </div>
                <span asp-validation-for="Input.Password" class="mt-1 text-sm text-red-600"></span>
            </div>

            <div class="flex items-center">
                <input asp-for="Input.RememberMe" class="size-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600" />
                <label asp-for="Input.RememberMe" class="ml-3 block text-sm/6 text-gray-900">
                    @Html.DisplayNameFor(m => m.Input.RememberMe)
                </label>
            </div>

            <div>
                <button id="login-submit" type="submit"
                        class="flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm/6 font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
                    Log in
                </button>
            </div>

            <div class="text-sm text-center">
                <a id="resend-confirmation" asp-page="./ResendEmailConfirmation" class="font-semibold text-indigo-600 hover:text-indigo-500">Resend email confirmation</a>
            </div>
        </form>

        <div class="mt-10">
            <div class="relative">
                <div class="absolute inset-0 flex items-center" aria-hidden="true">
                    <div class="w-full border-t border-gray-200"></div>
                </div>
                <div class="relative flex justify-center text-sm/6 font-medium">
                    <span class="bg-gray-100 px-6 text-gray-900">Or continue with</span>
                </div>
            </div>

            <div class="mt-6">
                @{
                    if ((Model.ExternalLogins?.Count ?? 0) == 0)
                    {
                        <p class="text-center text-sm text-gray-500">
                            No external authentication services configured. See this 
                            <a href="https://go.microsoft.com/fwlink/?LinkID=532715" class="font-semibold text-indigo-600 hover:text-indigo-500">article</a>
                            about setting up external login services.
                        </p>
                    }
                    else
                    {
                        <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="space-y-3">
                            @foreach (var provider in Model.ExternalLogins!)
                            {
                                <button type="submit" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account"
                                        class="flex w-full items-center justify-center gap-3 rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-xs ring-1 ring-gray-300 ring-inset hover:bg-gray-50 focus-visible:ring-transparent">
                                    @provider.DisplayName
                                </button>
                            }
                        </form>
                    }
                }
            </div>
        </div>

        <p class="mt-10 text-center text-sm/6 text-gray-500">
            Not a member?
            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="font-semibold text-indigo-600 hover:text-indigo-500">Register as a new user</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
