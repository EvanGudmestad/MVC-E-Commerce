@page
@model LogoutModel
@{
    ViewData["Title"] = "Log out";
}

<div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-sm">
        <h1 class="mt-10 text-center text-2xl/9 font-bold tracking-tight text-gray-900">@ViewData["Title"]</h1>
    </div>

    <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-sm">
        @{
            if (User.Identity?.IsAuthenticated ?? false)
            {
                <div class="rounded-md bg-white p-6 shadow-sm ring-1 ring-gray-900/5">
                    <p class="text-center text-sm/6 text-gray-600 mb-6">Are you sure you want to log out?</p>
                    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
                        <button type="submit"
                                class="flex w-full justify-center rounded-md bg-indigo-600 px-3 py-1.5 text-sm/6 font-semibold text-white shadow-xs hover:bg-indigo-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
                            Click here to Logout
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="rounded-md bg-green-50 p-6 text-center">
                    <svg class="mx-auto size-12 text-green-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                    </svg>
                    <p class="mt-4 text-sm/6 font-medium text-green-800">You have successfully logged out of the application.</p>
                    <div class="mt-6">
                        <a asp-page="/Account/Login" class="font-semibold text-indigo-600 hover:text-indigo-500">Sign in again</a>
                    </div>
                </div>
            }
        }
    </div>
</div>
